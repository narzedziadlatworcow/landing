---
interface Props {
  n: string;
  title: string;
  right?: string;
  align?: "left" | "center";
  class?: string;
}

const { n, title, right, align = "left", class: className } = Astro.props;

const cls = [
  "flex items-center gap-3 mb-8",
  align === "center" && "justify-center text-center",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div data-section-head class={cls}>
  <span
    data-head-num
    class="text-xs font-semibold tracking-widest uppercase text-muted inline-block"
  >
    {n}.
  </span>
  <span
    data-head-title
    class="text-xs font-semibold tracking-[0.18em] uppercase text-muted inline-block"
  >
    {title}
  </span>
  {
    right && (
      <span
        data-head-right
        class="ml-auto font-hand text-sm text-brand italic inline-block"
      >
        {right}
      </span>
    )
  }
</div>
