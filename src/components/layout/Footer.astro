---
const cols = [
  {
    title: "Produkt",
    links: [
      { label: "Strategia", href: "/#produkt" },
      { label: "Content", href: "/#produkt" },
      { label: "Inspiracje", href: "/#produkt" },
      { label: "Cennik", href: "/#pricing" },
    ],
  },
  {
    title: "Społeczność",
    links: [
      { label: "Discord", href: "#" },
      { label: "Newsletter", href: "/#pricing" },
      { label: "Kurs", href: "/#kurs" },
      { label: "Blog", href: "/blog" },
    ],
  },
  {
    title: "Kontakt",
    links: [
      { label: "hello@ndt.pl", href: "mailto:hello@ndt.pl" },
      { label: "Regulamin", href: "/regulamin" },
      { label: "Polityka prywatności", href: "/polityka-prywatnosci" },
    ],
  },
];

const year = new Date().getFullYear();
---

<footer class="bg-ink text-white mt-20">
  <div class="mx-auto max-w-[1200px] px-6 py-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-10">
      <div>
        <img
          src="/ndt-white.svg"
          alt="Narzędzia dla Twórców"
          width="152"
          height="40"
          class="h-10 w-auto mb-3"
        />
        <p class="text-white/60 text-[13px] leading-snug max-w-[200px]">
          Narzędzia dla Twórców. Zbuduj markę, której słuchają.
        </p>
      </div>

      {
        cols.map((col) => (
          <div>
            <h4 class="text-[10px] font-semibold tracking-[0.2em] uppercase text-white/45 mb-3">
              {col.title}
            </h4>
            <ul class="space-y-1.5">
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="text-[13px] text-white/75 hover:text-white transition-colors"
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-8 pt-4 border-t border-white/10 flex flex-wrap items-center justify-between gap-3 text-[11px] text-white/40"
    >
      <span>© {year} NDT · Narzędzia dla Twórców</span>
      <span class="font-hand text-[13px] text-white/55">
        Zrobione w Polsce · z głową
      </span>
    </div>
  </div>
</footer>
