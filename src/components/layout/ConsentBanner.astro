---
import Button from "@/components/ui/Button.astro";
---

<div
  data-consent
  hidden
  class="fixed bottom-4 left-4 right-4 sm:left-auto sm:right-6 sm:bottom-6 sm:max-w-md z-50"
  role="dialog"
  aria-label="Zgoda na pliki cookies"
>
  <div
    class="relative -rotate-[0.6deg] bg-white border border-border-soft rounded-xl p-5 sm:p-6 shadow-[0_12px_40px_-8px_hsl(266_51%_16%_/_0.18)]"
  >
    <span
      aria-hidden="true"
      class="absolute -top-2.5 left-7 h-5 w-14 rotate-[-3deg] rounded-[2px] bg-[hsl(52_97%_86%_/_0.85)] border border-[hsl(50_60%_56%_/_0.45)]"
    ></span>
    <h3 class="mb-1.5 text-base font-semibold text-ink">Pliki cookies</h3>
    <p class="mb-4 text-sm leading-relaxed text-muted">
      Za Twoją zgodą używamy cookies analitycznych (Google Analytics, Microsoft
      Clarity) i marketingowych (Meta, Google Ads, LinkedIn), żeby ulepszać tę
      stronę i nasze kampanie. Bez zgody strona działa tak samo. Szczegóły w
      <a href="/polityka-prywatnosci" class="underline hover:text-ink"
        >Polityce prywatności</a
      >.
    </p>

    {/* Panel granularny — domyślnie ukryty, rozwijany przyciskiem „Dostosuj" */}
    <div data-consent-detail hidden class="mb-4 flex flex-col gap-2.5">
      <label class="flex items-start gap-2.5 cursor-pointer text-sm text-ink">
        <input
          type="checkbox"
          data-consent-analytics
          class="mt-0.5 h-4 w-4 accent-brand"
        />
        <span>
          <span class="font-semibold block">Analityczne</span>
          <span class="text-muted">Jak korzystasz ze strony (GA4, Clarity).</span>
        </span>
      </label>
      <label class="flex items-start gap-2.5 cursor-pointer text-sm text-ink">
        <input
          type="checkbox"
          data-consent-marketing
          class="mt-0.5 h-4 w-4 accent-brand"
        />
        <span>
          <span class="font-semibold block">Marketingowe</span>
          <span class="text-muted">Personalizacja reklam (Meta, Ads, LinkedIn).</span>
        </span>
      </label>
      <Button variant="primary" size="md" class="mt-1 self-start" data-consent-save>
        Zapisz wybór
      </Button>
    </div>

    <div class="flex flex-col-reverse gap-2 sm:flex-row">
      <Button variant="ghost" size="md" class="sm:flex-1" data-consent-deny>
        Tylko niezbędne
      </Button>
      <Button variant="outline" size="md" class="sm:flex-1" data-consent-customize>
        Dostosuj
      </Button>
      <Button variant="primary" size="md" class="sm:flex-1" data-consent-accept>
        Akceptuję
      </Button>
    </div>
  </div>
</div>

<script>
  import { getStoredConsent, setConsent } from "@/lib/consent";

  const banner = document.querySelector<HTMLElement>("[data-consent]");
  const detail = banner?.querySelector<HTMLElement>("[data-consent-detail]");
  const cbAnalytics = banner?.querySelector<HTMLInputElement>(
    "[data-consent-analytics]"
  );
  const cbMarketing = banner?.querySelector<HTMLInputElement>(
    "[data-consent-marketing]"
  );

  const hide = () => {
    if (banner) banner.hidden = true;
  };
  const show = () => {
    if (banner) banner.hidden = false;
  };

  // Pierwsza wizyta → pokaż banner po krótkiej zwłoce.
  if (banner && getStoredConsent() === null) {
    setTimeout(show, 700);
  }

  // Ponowne otwarcie (przycisk „Zmień zgodę" w stopce) — prefill z zapisu.
  window.addEventListener("ndt:openConsent", () => {
    const stored = getStoredConsent();
    if (cbAnalytics) cbAnalytics.checked = !!stored?.analytics;
    if (cbMarketing) cbMarketing.checked = !!stored?.marketing;
    if (detail) detail.hidden = false;
    show();
  });

  banner?.querySelector("[data-consent-accept]")?.addEventListener("click", () => {
    setConsent({ analytics: true, marketing: true });
    hide();
  });
  banner?.querySelector("[data-consent-deny]")?.addEventListener("click", () => {
    setConsent({ analytics: false, marketing: false });
    hide();
  });
  banner
    ?.querySelector("[data-consent-customize]")
    ?.addEventListener("click", () => {
      if (detail) detail.hidden = !detail.hidden;
    });
  banner?.querySelector("[data-consent-save]")?.addEventListener("click", () => {
    setConsent({
      analytics: !!cbAnalytics?.checked,
      marketing: !!cbMarketing?.checked,
    });
    hide();
  });
</script>
