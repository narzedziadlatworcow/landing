---
import { Icon } from "astro-icon/components";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const formats = [
  { icon: "lucide:file-code-2", label: "Markdown", note: ".md", active: true },
  { icon: "lucide:file-text", label: "Word", note: ".docx", active: false },
  { icon: "lucide:file-down", label: "PDF", note: ".pdf", active: false },
];

const cls = [
  "glass-strong rounded-2xl p-3.5 text-ink select-none",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={cls}>
  <div
    class="text-[10px] font-semibold tracking-widest uppercase text-muted mb-2.5"
  >
    Eksport strategii
  </div>
  <div class="space-y-1.5">
    {
      formats.map((f) => {
        const rowCls = [
          "flex items-center gap-2.5 px-2.5 py-2 rounded-lg",
          f.active
            ? "bg-brand-soft border border-brand/30"
            : "bg-white/60 border border-border-soft",
        ].join(" ");
        const iconCls = [
          "size-4",
          f.active ? "text-brand" : "text-muted",
        ].join(" ");
        const labelCls = [
          "text-[12px] flex-1",
          f.active ? "text-ink font-medium" : "text-ink/70",
        ].join(" ");
        return (
          <div class={rowCls}>
            <Icon name={f.icon} class={iconCls} />
            <span class={labelCls}>{f.label}</span>
            <span class="text-[10px] text-muted font-mono">{f.note}</span>
            {f.active && <Icon name="lucide:check" class="size-3.5 text-brand" />}
          </div>
        );
      })
    }
  </div>
  <button
    class="w-full mt-3 bg-ink text-white text-[12px] py-2 rounded-lg font-medium"
  >
    Pobierz (.md)
  </button>
</div>
