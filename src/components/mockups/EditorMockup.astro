---
import { Icon } from "astro-icon/components";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const cls = [
  "glass-strong rounded-2xl overflow-hidden text-ink select-none",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={cls}>
  <div class="px-4 pt-4 pb-3 border-b border-border-soft/40 bg-white/40">
    <span class="inline-block text-[9px] px-1.5 py-0.5 rounded bg-brand-soft text-accent-strong font-semibold tracking-wider uppercase mb-1.5">
      YouTube · 8 min
    </span>
    <div class="text-[14px] font-semibold text-ink leading-snug">
      Jak zbudować markę osobistą w 2026
    </div>
  </div>

  <div class="p-4 space-y-3 bg-white/70">
    <div class="grid grid-cols-[1fr_92px] gap-3">
      <div>
        <div class="text-[9px] font-semibold tracking-wider uppercase text-brand mb-1">
          Hook
        </div>
        <div class="text-[12px] leading-relaxed text-ink/85">
          W 2019 miałem 2 000 followersów. Dziś <span class="bg-brand/15 px-0.5">ponad pół miliona</span>.
        </div>
      </div>
      <div class="flex items-start">
        <div class="flex items-center gap-1 text-[10px] bg-brand-soft/80 rounded px-1.5 py-1 border border-brand/20">
          <Icon name="lucide:image" class="size-3 text-brand" />
          <span class="text-accent-strong">Wizual</span>
        </div>
      </div>
    </div>

    <div class="rounded-lg bg-gradient-to-r from-brand-soft to-white border border-brand/25 p-2.5 flex items-start gap-2">
      <Icon name="lucide:sparkles" class="size-3.5 text-brand shrink-0 mt-0.5" />
      <div class="text-[11px] text-ink/85 italic leading-snug">
        „Doda­ję konkret z Twojej strategii: niszę B2C.”
      </div>
    </div>

    <div class="space-y-1.5 pt-1">
      <div class="h-1 rounded bg-subtle/90 w-[88%]"></div>
      <div class="h-1 rounded bg-subtle/90 w-[72%]"></div>
      <div class="h-1 rounded bg-subtle/90 w-[60%]"></div>
    </div>
  </div>
</div>
