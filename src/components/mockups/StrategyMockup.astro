---
import { Icon } from "astro-icon/components";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const stages = [
  { id: "channels", label: "Kanały", icon: "lucide:globe", progress: 1 },
  { id: "identity", label: "Tożsamość", icon: "lucide:fingerprint", progress: 1 },
  { id: "goals", label: "Cele", icon: "lucide:target", progress: 1 },
  { id: "audience", label: "Odbiorcy", icon: "lucide:users", progress: 0.62, active: true },
  { id: "style", label: "Styl", icon: "lucide:palette", progress: 0.15 },
  { id: "offer", label: "Oferta", icon: "lucide:package", progress: 0 },
  { id: "series", label: "Serie treści", icon: "lucide:layers", progress: 0 },
];

const cls = [
  "glass-strong rounded-2xl overflow-hidden text-ink select-none",
  "grid grid-cols-[180px_1fr]",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={cls}>
  <aside class="bg-gradient-to-b from-brand-soft/90 to-white/30 border-r border-border-soft/40 p-3">
    <div class="text-[10px] font-semibold tracking-[0.18em] uppercase text-muted px-2 pb-2 pt-1">
      Strategia
    </div>
    <ul class="space-y-0.5">
      {
        stages.map((s) => {
          const done = s.progress >= 1;
          const itemCls = [
            "flex items-center gap-2 px-2 py-1.5 rounded-md text-[12px]",
            s.active
              ? "bg-white shadow-sm border border-brand/25 text-ink font-medium"
              : "text-ink/75 hover:bg-white/50",
          ].join(" ");
          const iconWrapCls = [
            "grid place-items-center size-5 rounded-md shrink-0",
            done
              ? "bg-brand text-white"
              : s.active
                ? "bg-brand/15 text-brand"
                : "bg-white/70 text-muted border border-border-soft",
          ].join(" ");
          return (
            <li>
              <div class={itemCls}>
                <span class={iconWrapCls}>
                  {done ? (
                    <Icon name="lucide:check" class="size-3" />
                  ) : (
                    <Icon name={s.icon} class="size-3" />
                  )}
                </span>
                <span class="flex-1 truncate">{s.label}</span>
                {!done && s.progress > 0 && (
                  <span class="text-[9px] tabular-nums text-muted">
                    {Math.round(s.progress * 100)}%
                  </span>
                )}
              </div>
              {s.active && (
                <div class="mx-2 mt-1 h-1 bg-white/70 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-gradient-to-r from-brand to-brand-ring"
                    style={`width: ${s.progress * 100}%`}
                  />
                </div>
              )}
            </li>
          );
        })
      }
    </ul>
  </aside>

  <div class="p-4 bg-white/70">
    <div class="text-[10px] font-semibold tracking-widest uppercase text-brand mb-1">
      Etap 4 · Odbiorcy
    </div>
    <h3 class="text-[15px] font-semibold text-ink mb-3">
      Opisz 3 konkretne persony
    </h3>

    <div class="rounded-lg border border-brand/25 bg-brand-soft/50 p-3">
      <div class="flex items-center gap-2 mb-2">
        <div class="size-7 rounded-full bg-gradient-to-br from-brand to-brand-ring text-white grid place-items-center text-[11px] font-bold shadow-sm">
          KM
        </div>
        <div class="text-[12px] font-semibold text-ink">Kasia, 28</div>
      </div>
      <div class="h-1.5 rounded-full bg-white/80">
        <div class="h-full w-[80%] bg-brand/80 rounded-full"></div>
      </div>
    </div>
  </div>
</div>
