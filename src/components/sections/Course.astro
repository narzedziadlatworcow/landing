---
import { Icon } from "astro-icon/components";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import SectionHead from "@/components/ui/SectionHead.astro";

const modules = [
  { n: "01", t: "Tożsamość twórcy", time: "27 min" },
  { n: "02", t: "Cele twórcy", time: "24 min" },
  { n: "03", t: "Odbiorcy", time: "24 min" },
  { n: "04", t: "Styl komunikacji", time: "22 min" },
  { n: "05", t: "Format treści", time: "23 min" },
];

const bullets = [
  "10 lekcji video (ok. 2h) z Nikodemem, w 5 sekcjach",
  "Workbook strategii marki (PDF)",
  "Szablony: serii, tematów, kalendarza",
  "Dożywotni dostęp + przyszłe aktualizacje",
];
---

<section
  id="kurs"
  class="relative py-20 md:py-24 bg-gradient-to-b from-brand-soft/70 via-brand-soft/40 to-transparent border-y border-brand/20"
>
  <div class="mx-auto max-w-[1200px] px-6">
    <SectionHead
      n="06"
      title="Kurs — Nadaj treściom kierunek"
      right="prowadzi @Szhakal"
    />

    <div class="grid md:grid-cols-[1fr_1.05fr] gap-10 md:gap-14 items-center">
      {/* Left — pitch */}
      <div data-reveal>
        <Badge tone="brand" class="mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-brand" />
          10 lekcji · ok. 2h
        </Badge>

        <h2
          class="text-[36px] md:text-[44px] font-semibold tracking-tight text-ink leading-[1.05]"
        >
          Nikodem Rudziński
        </h2>
        <div
          class="mt-3 inline-flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[15px]"
        >
          <span class="font-semibold text-brand">@Szhakal</span>
          <span class="inline-flex items-baseline gap-1.5">
            <span class="font-bold text-ink tabular-nums">631K</span>
            <span class="text-muted text-[13px]">TikTok</span>
          </span>
          <span class="text-muted/40">·</span>
          <span class="inline-flex items-baseline gap-1.5">
            <span class="font-bold text-ink tabular-nums">151K</span>
            <span class="text-muted text-[13px]">Instagram</span>
          </span>
        </div>

        <p class="mt-6 text-[16px] text-ink/80 leading-relaxed max-w-[480px]">
          Kurs, który jest jednocześnie mapą produktu. Robisz ćwiczenia,
          wypełniasz strategię w aplikacji — kończysz z marką, a nie notesem
          notatek.
        </p>

        <ul class="mt-6 space-y-2.5 max-w-[480px]">
          {
            bullets.map((x) => (
              <li class="flex items-start gap-2.5 text-[15px] text-ink/85">
                <Icon
                  name="lucide:check-circle-2"
                  class="size-5 text-brand shrink-0 mt-0.5"
                />
                {x}
              </li>
            ))
          }
        </ul>

        <div class="mt-8 flex flex-wrap gap-3 items-center">
          <Button size="lg" variant="primary">
            Program kursu
            <Icon name="lucide:arrow-right" class="size-4" slot="right" />
          </Button>
          <Badge tone="muted">
            <Icon name="lucide:message-circle" class="size-3" slot="icon" />
            540+ twórców w społeczności
          </Badge>
        </div>
      </div>

      {/* Right — thumb + curriculum */}
      <div class="relative">
        {/* Thumb */}
        <div
          data-reveal
          class="relative rounded-2xl overflow-hidden border-[3px] border-ink shadow-[8px_8px_0_0_hsl(286_86%_57%)] aspect-video bg-gradient-to-br from-fuchsia-600 via-brand to-purple-800"
          style="transform: rotate(-1deg)"
        >
          <img
            src="/hqdefault.webp"
            alt="Kurs Nikodem Rudziński"
            class="w-full h-full object-cover opacity-90"
            loading="lazy"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-ink/40 via-transparent to-transparent"
          >
          </div>
          {/* Play button */}
          <button
            class="absolute inset-0 grid place-items-center group"
            aria-label="Zobacz zwiastun"
          >
            <span
              class="size-20 rounded-full bg-white/95 shadow-2xl grid place-items-center group-hover:scale-105 transition-transform"
            >
              <Icon
                name="lucide:play"
                class="size-8 text-brand fill-brand ml-1"
              />
            </span>
          </button>
          {/* Caption */}
          <div
            class="absolute bottom-3 left-4 right-4 flex items-end justify-between text-white"
          >
            <div>
              <div
                class="text-[11px] font-semibold tracking-widest uppercase opacity-80"
              >
                Zwiastun
              </div>
              <div class="text-[14px] font-semibold">
                Nadaj treściom kierunek · 2 min
              </div>
            </div>
            <span
              class="text-[11px] px-2 py-0.5 rounded-full bg-white/20 backdrop-blur border border-white/30 font-medium"
            >
              HD
            </span>
          </div>
        </div>

        {/* Curriculum peek */}
        <div
          data-reveal
          class="mt-6 glass rounded-xl p-4 max-w-[440px] mx-auto shadow-lg"
          style="transform: rotate(0.5deg)"
        >
          <div
            class="text-[10px] font-semibold tracking-widest uppercase text-muted mb-2.5"
          >
            Program kursu
          </div>
          <ul class="space-y-1.5">
            {
              modules.map((m) => (
                <li class="flex items-center gap-3 text-[13px] text-ink/85 hover:text-ink transition-colors">
                  <span class="text-brand font-mono font-semibold text-[11px] w-6">
                    {m.n}
                  </span>
                  <span class="flex-1 truncate">{m.t}</span>
                  <span class="text-[11px] text-muted tabular-nums">
                    {m.time}
                  </span>
                </li>
              ))
            }
            <li class="text-[11px] text-muted italic text-center pt-1">
              Każda sekcja = 2 lekcje video krok po kroku
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
