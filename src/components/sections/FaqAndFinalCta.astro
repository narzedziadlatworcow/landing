---
import { Icon } from "astro-icon/components";
import Button from "@/components/ui/Button.astro";
import SectionHead from "@/components/ui/SectionHead.astro";
import { faqs } from "@/data/faq";
import {
  LAUNCHED,
  CTA_LABEL,
  CTA_HREF,
  PRICE,
  PRICE_FIRST,
  LAUNCH_DATE,
} from "@/data/offer";
---

<section id="faq" class="py-20 md:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div
      class="grid md:grid-cols-[1.15fr_1fr] gap-10 md:gap-14 items-start"
    >
      {/* FAQ */}
      <div>
        <SectionHead n="09" title="FAQ" right="ostatnie wątpliwości" />
        <div data-reveal-group class="space-y-2.5">
          {
            faqs.map((f, i) => (
              <details
                data-reveal-item
                open={i === 0}
                class="group rounded-xl border bg-white/80 transition-all border-border-soft hover:border-brand/20 open:border-brand/30 open:shadow-[0_8px_24px_-12px_hsl(286_86%_57%_/_0.3)] [&[open]_.faq-plus]:rotate-45"
              >
                <summary class="w-full text-left px-5 py-3.5 flex items-center justify-between gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  <span class="font-semibold text-[15px] md:text-[16px] text-ink leading-snug">
                    {f.q}
                  </span>
                  <Icon
                    name="lucide:plus"
                    class="faq-plus size-4 text-brand shrink-0 transition-transform duration-300"
                  />
                </summary>
                <div class="overflow-hidden">
                  <div class="px-5 pb-4 space-y-2">
                    {f.lead && (
                      <p class="text-[14px] text-ink/75 leading-relaxed">
                        {f.lead}
                      </p>
                    )}
                    {f.bullets && (
                      <ul class="space-y-1.5">
                        {f.bullets.map((b) => (
                          <li class="flex items-start gap-2 text-[14px] text-ink/75 leading-relaxed">
                            <Icon
                              name="lucide:check"
                              class="size-3.5 text-brand shrink-0 mt-1"
                            />
                            <span>{b}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                    {f.a && (
                      <p class="text-[14px] text-ink/75 leading-relaxed">{f.a}</p>
                    )}
                  </div>
                </div>
              </details>
            ))
          }
        </div>
      </div>

      {/* Final CTA */}
      <div>
        <SectionHead n="10" title="Dołącz teraz" right="finał" />
        <div
          data-cta-card
          class="relative rounded-2xl border-[2.5px] border-ink bg-gradient-to-br from-brand-soft via-white to-brand-soft/40 shadow-[6px_6px_0_0_hsl(266_51%_16%)] p-7 md:p-8"
        >
          <h3
            data-cta-title
            class="text-[28px] md:text-[32px] font-semibold tracking-tight text-ink leading-tight"
          >
            Daj swoim treściom kierunek.
          </h3>
          <p
            data-cta-desc
            class="mt-3 text-[15px] text-ink/75 leading-relaxed"
          >
            {
              LAUNCHED ? (
                <>
                  Kurs, strategia i aplikacja w jednej subskrypcji, {PRICE}/mies.
                  Pełen dostęp od pierwszego dnia, anuluj kiedy chcesz.
                </>
              ) : (
                <>
                  Kurs, strategia i aplikacja w jednej subskrypcji. Start{" "}
                  {LAUNCH_DATE}. Zapisz się teraz i pierwszy miesiąc zapłać{" "}
                  {PRICE_FIRST} zamiast {PRICE}.
                </>
              )
            }
          </p>

          <div data-cta-buttons class="mt-7 flex flex-col gap-3">
            <Button size="lg" variant="primary" href={CTA_HREF} class="w-full">
              {CTA_LABEL}
              <Icon name="lucide:arrow-right" class="size-4" slot="right" />
            </Button>
          </div>

          <div
            data-cta-footer
            class="mt-5 flex items-start gap-2 text-[12px] text-muted"
          >
            <Icon
              name="lucide:message-circle"
              class="size-3.5 text-brand shrink-0 mt-1"
            />
            <span class="font-hand text-[14px] leading-snug">
              Discord polski-startup, otwarty dla wszystkich twórców.
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
