---
import { Icon } from "astro-icon/components";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import SectionHead from "@/components/ui/SectionHead.astro";
import {
  LAUNCHED,
  CHECKOUT_URL,
  PRICE,
  PRICE_UNIT,
  PRICE_FIRST,
  LAUNCH_DATE,
} from "@/data/offer";

// Co siedzi w jednej subskrypcji — trzy warstwy wartości (kurs → strategia → aplikacja).
const includes = [
  {
    eyebrow: "Kurs",
    title: "Nadaj treściom kierunek",
    desc: "5-6 modułów video ze mną (ok. 30-40 min), workbook strategii marki (PDF) i szablony serii, tematów oraz kalendarza.",
  },
  {
    eyebrow: "Strategia",
    title: "7 etapów, krok po kroku",
    desc: "Kanały, Tożsamość, Cele, Odbiorcy, Styl, Oferta, Serie treści. AI prowadzi cię za rękę, a ty decydujesz.",
  },
  {
    eyebrow: "Aplikacja",
    title: "Pomysły i tworzenie w jednym miejscu",
    desc: "Inspiracje z YouTube i ulubionych stron (z oceną AI), edytor treści na każdy format z pamięcią marki, biblioteka marki i miesięczny pakiet AI do pisania.",
  },
];

const reassurance = [
  "Pełen dostęp od pierwszego dnia",
  "Anuluj kiedy chcesz, zero zobowiązań",
  "Po polsku, dla twórców, nie dla korpo",
];
---

<section data-anim-pricing id="pricing" class="py-20 md:py-28 relative">
  <div class="relative mx-auto max-w-[1200px] px-6">
    <SectionHead n="08" title="Cennik · jedno wejście" right="moment decyzji" />

    <div class="text-center mb-10 md:mb-14">
      <h2
        data-pricing-headline
        class="font-semibold tracking-tight text-ink leading-[1.08] text-[36px] md:text-[48px]"
      >
        Jedno wejście. Cały system.
      </h2>
      <p
        data-pricing-sub
        class="mt-4 text-ink/70 text-[16px] max-w-[620px] mx-auto"
      >
        {
          LAUNCHED ? (
            <>
              Kurs, strategia i aplikacja w jednej subskrypcji. Anuluj kiedy
              chcesz.
            </>
          ) : (
            <>
              Kurs, strategia i aplikacja w jednej subskrypcji. Start{" "}
              {LAUNCH_DATE}: zapisz się teraz, a pierwszy miesiąc zapłacisz{" "}
              {PRICE_FIRST} zamiast {PRICE}.
            </>
          )
        }
      </p>
    </div>

    <div class="grid md:grid-cols-[1fr_1.05fr] gap-6 md:gap-8 items-start">
      {/* LEWA — cena + CTA (karta-bohater) */}
      <div
        data-pricing-card
        class="relative rounded-2xl p-6 md:p-7 bg-gradient-to-br from-white via-brand-soft/30 to-white border-[2.5px] border-ink shadow-[6px_6px_0_0_hsl(286_86%_57%)] flex flex-col"
      >
        {!LAUNCHED && (
          <div class="absolute -top-3.5 left-6">
            <Badge tone="brand">
              <Icon name="lucide:zap" class="size-3" slot="icon" />
              Start {LAUNCH_DATE}
            </Badge>
          </div>
        )}

        <div
          class="text-[11px] font-semibold tracking-[0.18em] uppercase text-brand mt-2"
        >
          Subskrypcja NDT
        </div>

        <div class="mt-3 flex items-baseline gap-1.5">
          <span
            class="font-bold leading-none tracking-tight text-[52px] text-ink"
          >
            {PRICE}
          </span>
          <span class="text-[16px] text-muted font-normal">{PRICE_UNIT}</span>
        </div>

        {
          !LAUNCHED && (
            <p class="mt-2 font-scribble text-brand text-[20px] leading-snug">
              pierwszy miesiąc {PRICE_FIRST} →
            </p>
          )
        }

        <div class="my-5 h-px bg-ink/15"></div>

        <ul class="space-y-2.5 mb-6 flex-1">
          {
            reassurance.map((r) => (
              <li class="flex items-start gap-2.5 text-[14px] leading-snug text-ink/85">
                <Icon
                  name="lucide:check"
                  class="size-4 text-brand shrink-0 mt-0.5"
                />
                {r}
              </li>
            ))
          }
        </ul>

        {/* CTA — pre-launch: zapis na newsletter (kupon na pierwszy miesiąc). Po: redirect na checkout. */}
        <div class="mt-auto">
          {
            LAUNCHED ? (
              <Button
                variant="primary"
                size="lg"
                href={CHECKOUT_URL}
                class="w-full"
              >
                Zacznij za {PRICE}
                {PRICE_UNIT}
                <Icon name="lucide:arrow-right" class="size-4" slot="right" />
              </Button>
            ) : (
              <>
                <div id="signup-area">
                  <div class="text-[13px] text-ink/70 text-center mb-2.5 leading-snug">
                    Zapisz się, a 15.06 dostaniesz kupon na{" "}
                    <b class="text-ink">pierwszy miesiąc {PRICE_FIRST}</b>.
                  </div>
                  <form id="signup-form" class="flex flex-col gap-1.5">
                    <div class="flex gap-1.5">
                      <input
                        type="email"
                        name="email"
                        required
                        placeholder="Twój e-mail"
                        class="flex-1 min-w-0 px-3 py-2.5 text-[14px] rounded-lg border border-border-soft bg-white/80 text-ink focus:outline-none focus:border-brand/60 transition-colors"
                      />
                      <button
                        type="submit"
                        aria-label="Zapisz się i odbierz kupon"
                        class="px-4 py-2.5 text-[14px] font-semibold text-white bg-brand rounded-lg shadow-[0_4px_14px_-2px_hsl(286_86%_57%_/_0.45)] hover:bg-brand/90 transition-colors disabled:opacity-60"
                      >
                        →
                      </button>
                    </div>
                    {/* honeypot: ukryte przed ludźmi, boty wypełniają */}
                    <input
                      type="text"
                      name="website"
                      tabindex="-1"
                      autocomplete="off"
                      class="hidden"
                      aria-hidden="true"
                    />
                  </form>
                  <p class="text-[11px] text-muted text-center mt-2 leading-snug">
                    Zapisując się, akceptujesz{" "}
                    <a href="/regulamin" class="underline">
                      Regulamin newslettera
                    </a>{" "}
                    i zgadzasz się na otrzymanie maila z kuponem oraz
                    okazjonalnych wiadomości. Wypisz się w każdej chwili. Zobacz{" "}
                    <a href="/polityka-prywatnosci" class="underline">
                      Politykę prywatności
                    </a>.
                  </p>
                  <p
                    id="signup-msg"
                    class="hidden text-[13px] text-center mt-2 font-semibold text-red-600"
                  >
                  </p>
                </div>

                {/* Stan po zapisie — wyraźny, zastępuje formularz */}
                <div
                  id="signup-success"
                  class="hidden rounded-xl border border-brand/30 bg-brand-soft px-5 py-5 text-center"
                >
                  <div class="text-[32px] leading-none mb-2">✉️</div>
                  <div class="text-[17px] font-semibold text-ink">
                    Prawie gotowe — sprawdź skrzynkę!
                  </div>
                  <div class="text-[13px] text-ink/70 mt-1.5 leading-snug">
                    Wysłaliśmy link potwierdzający na Twój e-mail. Kliknij go,
                    żeby odebrać kupon na{" "}
                    <b class="text-ink">pierwszy miesiąc {PRICE_FIRST}</b>.
                  </div>
                  <div class="text-[11px] text-muted mt-2">
                    Nie widzisz wiadomości? Zajrzyj do spamu lub ofert.
                  </div>
                </div>

                <script>
                  const form = document.getElementById("signup-form");
                  const area = document.getElementById("signup-area");
                  const success = document.getElementById("signup-success");
                  const msg = document.getElementById("signup-msg");
                  const API = import.meta.env.PUBLIC_MAILING_API_URL;
                  form?.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    const btn = form.querySelector("button[type=submit]");
                    const data = new FormData(form);
                    btn.disabled = true;
                    msg?.classList.add("hidden");
                    try {
                      // text/plain → request "prosty" (bez preflight OPTIONS).
                      await fetch(`${API}/route/mailing/subscribe`, {
                        method: "POST",
                        headers: { "Content-Type": "text/plain" },
                        body: JSON.stringify({
                          email: data.get("email"),
                          website: data.get("website"),
                        }),
                      });
                      // Wspólny event konwersji — GTM odpala na nim GA4 / Meta / Ads / LinkedIn.
                      (window as unknown as { dataLayer?: unknown[] }).dataLayer ||= [];
                      (window as unknown as { dataLayer: unknown[] }).dataLayer.push({
                        event: "generate_lead",
                        form_location: "pricing",
                      });
                      // Zamiana stanu: chowamy formularz, pokazujemy box sukcesu.
                      area?.classList.add("hidden");
                      success?.classList.remove("hidden");
                      success?.scrollIntoView({ behavior: "smooth", block: "center" });
                    } catch {
                      if (msg) {
                        msg.textContent = "Coś poszło nie tak. Spróbuj ponownie.";
                        msg.classList.remove("hidden");
                      }
                      btn.disabled = false;
                    }
                  });
                </script>
              </>
            )
          }
        </div>
      </div>

      {/* PRAWA — co dostajesz w środku */}
      <div
        data-pricing-card
        class="relative rounded-2xl p-6 md:p-7 bg-white/90 border border-border-soft shadow-[0_10px_30px_-12px_hsl(266_51%_16%_/_0.15)]"
      >
        <div
          class="text-[11px] font-semibold tracking-[0.18em] uppercase text-muted mb-1"
        >
          Wszystko w cenie
        </div>
        <h3 class="font-semibold text-ink text-[20px] mb-5">
          Co dostajesz w jednej subskrypcji
        </h3>

        <div class="space-y-5">
          {
            includes.map((it) => (
              <div class="flex items-start gap-3.5">
                <Icon
                  name="lucide:check-circle-2"
                  class="size-5 text-brand shrink-0 mt-0.5"
                />
                <div>
                  <div class="flex items-baseline gap-2">
                    <span class="text-[11px] font-semibold tracking-[0.16em] uppercase text-brand">
                      {it.eyebrow}
                    </span>
                    <span class="font-semibold text-ink text-[15px]">
                      {it.title}
                    </span>
                  </div>
                  <p class="mt-1 text-[13.5px] text-ink/70 leading-relaxed">
                    {it.desc}
                  </p>
                </div>
              </div>
            ))
          }
        </div>

        <p class="mt-6 font-hand text-[15px] text-muted leading-snug">
          Wychodzisz z gotową marką i pierwszymi treściami, nie z notesem notatek.
        </p>
      </div>
    </div>
  </div>
</section>
