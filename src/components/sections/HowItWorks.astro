---
import SectionHead from "@/components/ui/SectionHead.astro";
import StrategyMockup from "@/components/mockups/StrategyMockup.astro";
import InspirationMockup from "@/components/mockups/InspirationMockup.astro";
import EditorMockup from "@/components/mockups/EditorMockup.astro";

const steps = [
  {
    t: "Strategia",
    d: "7 etapów: Kanały, Tożsamość, Cele, Odbiorcy, Styl, Oferta, Serie treści. AI prowadzi cię za rękę, a ty podejmujesz decyzje.",
    meta: "~75 min · jednorazowo",
    Mockup: StrategyMockup,
  },
  {
    t: "Pomysły",
    d: "Filmy z YouTube i ulubione strony w jednym miejscu, a AI podpowiada, które tematy naprawdę pasują do twojej niszy.",
    meta: "YouTube · ulubione strony · zapisane",
    Mockup: InspirationMockup,
  },
  {
    t: "Pisanie",
    d: "Edytor pamięta twoją markę. Piszesz pod każdy format: rolkę, post, film czy karuzelę. Przy każdym fragmencie zaznaczasz, co pokazać.",
    meta: "31 formatów · AI zna twój styl",
    Mockup: EditorMockup,
  },
];
---

<section id="produkt" class="relative">
  <div class="mx-auto max-w-[1200px] px-6 pt-14 md:pt-20">
    <SectionHead n="05" title="Jak to działa" right="trzy kroki, jeden proces" />
  </div>

  <div class="pb-12">
    {
      steps.map((s, i) => {
        const reversed = i % 2 === 1;
        const Mockup = s.Mockup;
        const copyCls = reversed ? "md:order-2" : "";
        const mockupWrapCls = `relative ${reversed ? "md:order-1" : ""}`;
        return (
          <div data-step={i} class="py-14 md:py-20">
            <div class="mx-auto max-w-[1200px] w-full px-6">
              <div class="grid md:grid-cols-[1fr_1.15fr] gap-8 md:gap-12 items-center">
                <div class={copyCls}>
                  <div class="flex items-start gap-4">
                    <div data-num class="size-10 rounded-xl bg-gradient-to-br from-brand to-brand-ring text-white font-bold grid place-items-center text-[15px] shadow-[0_4px_14px_-2px_hsl(286_86%_57%_/_0.4)] shrink-0">
                      {i + 1}
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center gap-3 flex-wrap">
                        <h3 data-title class="text-2xl md:text-[28px] font-semibold text-ink tracking-tight">
                          {s.t}
                        </h3>
                        <span data-meta class="font-hand text-brand text-[15px] inline-block">
                          {s.meta}
                        </span>
                      </div>
                      <p data-desc class="mt-3 text-ink/75 text-[16px] leading-relaxed max-w-[440px]">
                        {s.d}
                      </p>
                    </div>
                  </div>
                </div>

                <div class={mockupWrapCls}>
                  <div data-mockup>
                    <Mockup class="w-full max-w-[540px] mx-auto shadow-[0_20px_40px_-16px_hsl(266_51%_16%_/_0.2)]" />
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</section>
