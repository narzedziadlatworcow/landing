---
import Base from "@/layouts/Base.astro";
import Nav from "@/components/layout/Nav.astro";
import Badge from "@/components/ui/Badge.astro";
import ScribbleAnno from "@/components/ui/ScribbleAnno.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import defaultCover from "@/assets/blog-cover-default.png";

interface Frontmatter {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  cover?: string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const { title, description, publishDate, updatedDate, author, tags, cover } =
  frontmatter;

const dateFmt = new Intl.DateTimeFormat("pl-PL", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const publishedLabel = dateFmt.format(publishDate);
const updatedLabel = updatedDate ? dateFmt.format(updatedDate) : null;

const site = Astro.site ?? new URL("https://narzedziadlatworcow.pl");
const canonical = new URL(Astro.url.pathname, site).href;
// Fallback na domyślny cover, gdy wpis nie ma własnego — spójne hero + OG.
const coverImg = cover ?? defaultCover;
const imageAbs = new URL(coverImg.src, site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  author: { "@type": "Person", name: author },
  image: imageAbs,
  mainEntityOfPage: canonical,
};
---

<Base
  title={`${title} · Blog NDT`}
  description={description}
  type="article"
  image={coverImg.src}
  jsonLd={jsonLd}
>
  <Nav />
  <main class="mx-auto max-w-[760px] px-6 py-16 sm:py-20">
    <a
      href="/blog"
      class="group inline-flex items-center gap-2 text-sm font-medium text-muted transition-colors hover:text-brand"
    >
      <Icon
        name="lucide:arrow-left"
        class="size-4 transition-transform group-hover:-translate-x-0.5"
      />
      Wróć na blog
    </a>

    <header data-reveal class="mt-8 mb-10">
      {
        tags.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <Badge tone="brand">{tag}</Badge>
            ))}
          </div>
        )
      }

      <h1 class="text-3xl font-semibold leading-tight tracking-tight text-ink sm:text-[2.6rem] sm:leading-[1.1]">
        {title}
      </h1>

      <p class="mt-4 text-lg text-muted">{description}</p>

      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-muted">
        <span class="font-medium text-ink">{author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={publishDate.toISOString()}>{publishedLabel}</time>
        {
          updatedLabel && (
            <>
              <span aria-hidden="true">·</span>
              <span class="italic">akt. {updatedLabel}</span>
            </>
          )
        }
      </div>
    </header>

    <figure data-reveal class="relative mb-10 -rotate-1">
      <span
        class="tape"
        style="top: -10px; left: 32px; transform: rotate(-5deg);"
        aria-hidden="true"
      />
      <span
        class="tape"
        style="top: -10px; right: 32px; transform: rotate(4deg);"
        aria-hidden="true"
      />
      <Image
        src={coverImg}
        alt={title}
        width={1200}
        height={675}
        loading="eager"
        class="w-full rounded-xl border-2 border-ink object-cover shadow-[4px_4px_0_0_hsl(266_51%_16%)]"
      />
    </figure>

    <article data-reveal class="post-body">
      <slot />
    </article>

    <hr class="my-12 border-0 border-t border-dashed border-border-soft" />

    <div class="flex items-center justify-between gap-4">
      <a
        href="/blog"
        class="group inline-flex items-center gap-2 text-sm font-medium text-muted transition-colors hover:text-brand"
      >
        <Icon
          name="lucide:arrow-left"
          class="size-4 transition-transform group-hover:-translate-x-0.5"
        />
        Wróć na blog
      </a>
      <ScribbleAnno rotate={-3} size="md">do zobaczenia!</ScribbleAnno>
    </div>
  </main>
</Base>

<style>
  /* Ręczny "prose" — brak pluginu typografii, styl markowy i czytelny. */
  .post-body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: hsl(266 51% 16% / 0.92);
  }
  .post-body :global(h2) {
    font-size: 1.6rem;
    line-height: 1.25;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 0.9rem;
  }
  .post-body :global(h3) {
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 600;
    color: var(--color-ink);
    margin-top: 1.9rem;
    margin-bottom: 0.6rem;
  }
  .post-body :global(p) {
    margin-block: 1.1rem;
  }
  /* Tylko linki z treści (markdown = <a> bez klasy). Przyciski/komponenty
     mają własne klasy → :not([class]) chroni je przed kolorem prozy. */
  .post-body :global(a:not([class])) {
    color: var(--color-brand);
    font-weight: 500;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: hsl(286 86% 57% / 0.4);
  }
  .post-body :global(a:not([class]):hover) {
    text-decoration-color: var(--color-brand);
  }
  .post-body :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin-block: 1.1rem;
    padding-left: 1.4rem;
  }
  .post-body :global(ul) {
    list-style: none;
  }
  .post-body :global(ul > li) {
    position: relative;
    margin-block: 0.4rem;
  }
  .post-body :global(ul > li)::before {
    content: "";
    position: absolute;
    left: -1.1rem;
    top: 0.7em;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--color-brand);
  }
  .post-body :global(ol) {
    list-style: decimal;
  }
  .post-body :global(ol > li) {
    margin-block: 0.4rem;
    padding-left: 0.3rem;
  }
  .post-body :global(ol > li::marker) {
    color: var(--color-brand);
    font-weight: 600;
  }
  .post-body :global(blockquote) {
    margin-block: 1.6rem;
    padding: 0.4rem 0 0.4rem 1.2rem;
    border-left: 3px solid var(--color-brand);
    font-family: var(--font-hand);
    font-size: 1.35rem;
    line-height: 1.5;
    color: var(--color-accent-strong);
  }
  .post-body :global(blockquote p) {
    margin-block: 0.3rem;
  }
  .post-body :global(code) {
    font-size: 0.9em;
    background: var(--color-subtle);
    padding: 0.12em 0.4em;
    border-radius: 0.35rem;
    border: 1px solid var(--color-border-soft);
  }
  .post-body :global(pre) {
    margin-block: 1.4rem;
    padding: 1rem 1.2rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    border: 1px solid var(--color-border-soft);
  }
  .post-body :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
  }
  .post-body :global(img) {
    border-radius: 0.75rem;
    margin-block: 1.6rem;
  }
  .post-body :global(hr) {
    margin-block: 2rem;
    border: 0;
    border-top: 1px dashed var(--color-border-soft);
  }
</style>
