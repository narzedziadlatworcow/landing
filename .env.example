# URL aplikacji NDT, do której landing wysyła zapis na listę mailingową.
# Prod: https://app.narzedziadlatworcow.pl, dev: http://localhost:5005
PUBLIC_MAILING_API_URL=https://app.narzedziadlatworcow.pl

# Google Tag Manager — jedyny loader tagów (GA4, Clarity, Meta, Ads, LinkedIn w panelu GTM).
# Wklej ID kontenera po jego założeniu; dopóki puste, GTM się nie ładuje.
# Uwaga: analityka NDT odpala się tylko w produkcyjnym buildzie (import.meta.env.PROD).
PUBLIC_GTM_ID=
